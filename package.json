{
  "name": "faraday-tauri",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:frdye": "cd src-tauri && cargo build -p frdye",
    "build:frdye:release": "cd src-tauri && cargo build -p frdye --release",
    "preview": "vite preview",
    "tauri": "tauri",
    "build:web": "vite build --config vite.web.config.ts",
    "dev:web": "vite dev --config vite.web.config.ts",
    "build:server": "cd src-tauri && cargo build -p faraday-server --release",
    "build:server:dev": "cd src-tauri && cargo build -p faraday-server"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "fss-lang": "^0.0.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  },
  "packageManager": "pnpm@10.30.3"
}
